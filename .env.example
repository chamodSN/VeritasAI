# copy to .env and fill in real values

# Application
ENVIRONMENT=development          # development | production
DEBUG=true
LOG_LEVEL=INFO
LOG_DIR=./logs

# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
API_BASE_URL=https://api.openai.com/v1
TEMPERATURE=0.4

# Database — MongoDB Atlas (NOT a local/Docker MongoDB instance)
# Get this from Atlas: Database > Connect > Drivers > Python
MONGO_URI=mongodb+srv://veritasai_app:CHANGE_ME@veritasai-cluster.xxxxx.mongodb.net/veritas_ai?retryWrites=true&w=majority&appName=VeritasAI
DATABASE_NAME=veritas_ai

# Redis — cache, rate limiter, job queue (local/Docker)
REDIS_URL=redis://redis:6379/0

# Auth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRY_HOURS=24
SESSION_SECRET_KEY=another-long-random-string

# Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Admin
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=

# External APIs
COURTLISTENER_API_KEY=your-courtlistener-api-key

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000